{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/approve-planning-writes.sh \"$TOOL_INPUT\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/check-plugin-antipatterns.sh \"$TOOL_INPUT\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/validate-plugin-structure.sh \"$TOOL_INPUT\"",
            "timeout": 5
          },
          {
            "type": "prompt",
            "prompt": "If this write targets a Moku plugin file (*/plugins/*/index.ts), verify: 1) index.ts is under ~30 lines of wiring (imports + createPlugin call), no business logic inline. 2) No explicit generics on createPlugin/createCorePlugin. 3) onStart/onStop only present if managing a resource (server, connection, listener). If the file is NOT a plugin index.ts, approve immediately. Return 'approve' if valid. If invalid, return 'deny' with: the specific rule violated AND the fix. Example approval: 'approve — 28 lines, wiring only, no explicit generics, no lifecycle.' Example denial: 'deny — Rule 1 violated: 45 lines with inline bcrypt logic on lines 15-38. Fix: extract to api.ts as createAuthApi factory, import in index.ts.'",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/format-on-save.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/precompact-state.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/detect-moku-project.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/log-notification.sh \"$TOOL_INPUT\"",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/user-prompt-context.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "moku-.*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/on-subagent-stop.sh \"$TOOL_INPUT\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-end.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
