{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/approve-planning-writes.sh \"$TOOL_INPUT\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f biome.json ] && [ -f package.json ] && grep -q '\"format\"' package.json 2>/dev/null && ([ -f src/config.ts ] || [ -d .planning ]); then bun run format 2>&1 || echo 'Format failed with exit code '$?; fi",
            "timeout": 15
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f .planning/STATE.md ]; then echo '## Moku Planning State (re-injected before compaction)'; cat .planning/STATE.md; fi",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/detect-moku-project.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
